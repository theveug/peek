APP_NAME=Peek
APP_VERSION=0.1.0

# TURN relay for internet deployments where direct P2P fails (symmetric NAT).
# The relay is blind — it forwards encrypted bytes, it can't read media.
TURN_URL=turn:turn.domain.com:3478
TURN_SECRET=your_shared_secret_here

# Optional public STUN for internet deployments WITHOUT a TURN server.
# There is deliberately no built-in default (there used to be Google's) — a
# third-party STUN server sees every participant's IP on every call. Not
# needed on a LAN (host candidates connect directly) or when TURN is set
# (a TURN allocation already yields the server-reflexive candidate).
#STUN_URL=stun:stun.yourdomain.com:3478

# Set when deployed behind a reverse proxy (nginx/caddy/cloudflared) so the
# per-IP rate limits see real client IPs instead of the proxy's. "1" = trust
# one hop; any other value is passed to Express's 'trust proxy' as-is.
# Never set this when clients connect directly — it lets them spoof their IP.
#TRUST_PROXY=1

# Server-side debug logging (room codes/names to stdout). Off by default so a
# deployment's captured stdout never accumulates call metadata.
#DEBUG=1
